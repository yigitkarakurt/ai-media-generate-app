	"item": [
		{
			"name": "Health",
			"description": "Public service checks.",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"returns success\", function () {",
									"  var json = pm.response.json();",
									"  pm.expect(json.success).to.eql(true);",
									"  pm.expect(json.data.status).to.eql(\"ok\");",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"description": "GET `/api/health`. Public health probe. Expected response shape: `{ success: true, data: { status, timestamp } }`.",
						"url": {
							"raw": "{{baseUrl}}/api/health",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"health"
							]
						}
					},
					"response": []
				},
				{
					"name": "Version",
					"request": {
						"method": "GET",
						"header": [],
						"description": "GET `/api/version`. Public version check. Expected response shape: `{ success: true, data: { version, environment } }`.",
						"url": {
							"raw": "{{baseUrl}}/api/version",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"version"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Mobile / Filters",
			"description": "Mobile-safe active filter catalog. These routes are currently public in code.",
			"item": [
				{
					"name": "List Active Filters",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"returns paginated success\", function () {",
									"  var json = pm.response.json();",
									"  pm.expect(json.success).to.eql(true);",
									"  pm.expect(json.data).to.be.an(\"array\");",
									"});",
									"",
									"var json = pm.response.json();",
									"if (json.success && json.data && json.data.length > 0) {",
									"  pm.collectionVariables.set(\"filterId\", json.data[0].id);",
									"  pm.collectionVariables.set(\"filterSlug\", json.data[0].slug);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"description": "GET `/api/mobile/filters`. Lists active filters only. Query params: `page`, `pageSize`. The test script stores the first returned `filterId` and `filterSlug` if any filters exist.",
						"url": {
							"raw": "{{baseUrl}}/api/mobile/filters?page={{page}}&pageSize={{pageSize}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"mobile",
								"filters"
							],
							"query": [
								{
									"key": "page",
									"value": "{{page}}"
								},
								{
									"key": "pageSize",
									"value": "{{pageSize}}"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Filter by Slug",
					"request": {
						"method": "GET",
						"header": [],
						"description": "GET `/api/mobile/filters/:slug`. Mobile-safe filter detail by slug. Uses `filterSlug` from the list or admin create-filter step.",
						"url": {
							"raw": "{{baseUrl}}/api/mobile/filters/{{filterSlug}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"mobile",
								"filters",
								"{{filterSlug}}"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Mobile / Uploads",
			"description": "Authenticated mobile upload flow. The backend creates an input asset and returns a presigned R2 PUT URL. The file upload itself goes directly to R2.",
			"item": [
				{
					"name": "Request Upload URL",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"created upload request\", function () {",
									"  pm.response.to.have.status(201);",
									"  var json = pm.response.json();",
									"  pm.expect(json.success).to.eql(true);",
									"  pm.expect(json.data.assetId).to.be.a(\"string\");",
									"  pm.expect(json.data.uploadUrl).to.be.a(\"string\");",
									"});",
									"",
									"var json = pm.response.json();",
									"if (json.success && json.data) {",
									"  pm.collectionVariables.set(\"assetId\", json.data.assetId);",
									"  pm.collectionVariables.set(\"uploadUrl\", json.data.uploadUrl);",
									"  pm.collectionVariables.set(\"storageKey\", json.data.storageKey);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Dev-User-Id",
								"value": "{{devUserId}}",
								"description": "Development auth header required by mobile upload routes."
							}
						],
						"description": "POST `/api/mobile/uploads/request`. Body validation: `filename` 1-255 chars, `mimeType` must be one of image/jpeg, image/png, image/webp, image/heic, image/heif, video/mp4, video/quicktime, video/webm, and `fileSizeBytes` must be a positive integer <= 104857600.",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filename\": \"{{uploadFilename}}\",\n  \"mimeType\": \"{{uploadMimeType}}\",\n  \"fileSizeBytes\": {{uploadFileSizeBytes}}\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/mobile/uploads/request",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"mobile",
								"uploads",
								"request"
							]
						}
					},
					"response": []
				},
				{
					"name": "Upload File to Signed R2 URL",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "{{uploadMimeType}}"
							}
						],
						"description": "PUT `{{uploadUrl}}`. This is not a Worker API route; it uploads the binary file directly to the presigned R2 URL returned by `Request Upload URL`. In Postman, select a local file in the Body file picker before sending. If the signed URL expires, rerun `Request Upload URL`.",
						"body": {
							"mode": "file",
							"file": {
								"src": ""
							}
						},
						"url": "{{uploadUrl}}"
					},
					"response": []
				},
				{
					"name": "Confirm Upload",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"asset is uploaded\", function () {",
									"  var json = pm.response.json();",
									"  pm.expect(json.success).to.eql(true);",
									"  pm.expect(json.data.status).to.eql(\"uploaded\");",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Dev-User-Id",
								"value": "{{devUserId}}",
								"description": "Development auth header required by mobile upload routes."
							}
						],
						"description": "POST `/api/mobile/uploads/confirm`. Marks a pending asset as uploaded after the direct R2 upload. `assetId` must be a UUID owned by `X-Dev-User-Id`; optional metadata fields are positive numbers/integers as implemented.",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"assetId\": \"{{assetId}}\",\n  \"fileSizeBytes\": {{uploadFileSizeBytes}},\n  \"mimeType\": \"{{uploadMimeType}}\",\n  \"width\": 1024,\n  \"height\": 1024\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/mobile/uploads/confirm",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"mobile",
								"uploads",
								"confirm"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Mobile / Generations",
			"description": "Authenticated mobile generation submission and status reads.",
			"item": [
				{
					"name": "Create Generation",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"generation created\", function () {",
									"  pm.response.to.have.status(201);",
									"  var json = pm.response.json();",
									"  pm.expect(json.success).to.eql(true);",
									"  pm.expect(json.data.id).to.be.a(\"string\");",
									"});",
									"",
									"var json = pm.response.json();",
									"if (json.success && json.data) {",
									"  pm.collectionVariables.set(\"generationId\", json.data.id);",
									"  if (json.data.output_asset_id) pm.collectionVariables.set(\"outputAssetId\", json.data.output_asset_id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Dev-User-Id",
								"value": "{{devUserId}}",
								"description": "Development auth header required by mobile generation routes."
							}
						],
						"description": "POST `/api/mobile/generations`. Requires an uploaded input asset owned by `devUserId` and an active filter whose `input_media_types` includes the asset media type. The client sends `filter_id`, `input_asset_id`, and optional provider params only; prompts and provider API keys remain backend-owned.",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filter_id\": \"{{filterId}}\",\n  \"input_asset_id\": \"{{assetId}}\",\n  \"params\": {\n    \"seed\": 12345\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/mobile/generations",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"mobile",
								"generations"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Generation Detail",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"if (json.success && json.data && json.data.output_asset_id) {",
									"  pm.collectionVariables.set(\"outputAssetId\", json.data.output_asset_id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Dev-User-Id",
								"value": "{{devUserId}}",
								"description": "Development auth header required by mobile generation routes."
							}
						],
						"description": "GET `/api/mobile/generations/:id`. Returns client-safe generation fields. If the job is completed and linked to an output asset, response also includes `output_asset` with a signed `read_url`.",
						"url": {
							"raw": "{{baseUrl}}/api/mobile/generations/{{generationId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"mobile",
								"generations",
								"{{generationId}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "List Generations",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Dev-User-Id",
								"value": "{{devUserId}}",
								"description": "Development auth header required by mobile generation routes."
							}
						],
						"description": "GET `/api/mobile/generations`. Lists the authenticated user's generation jobs. Supported status query values: `queued`, `processing`, `completed`, `failed`.",
						"url": {
							"raw": "{{baseUrl}}/api/mobile/generations?page={{page}}&pageSize={{pageSize}}&status={{generationStatus}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"mobile",
								"generations"
							],
							"query": [
								{
									"key": "page",
									"value": "{{page}}"
								},
								{
									"key": "pageSize",
									"value": "{{pageSize}}"
								},
								{
									"key": "status",
									"value": "{{generationStatus}}",
									"description": "queued, processing, completed, or failed"
								}
							]
						}
					},
					"response": []
				}
			]
		},
