{
	"name": "ai-media-generate-app",
	"description": "Backend API for AI media generation platform. Cloudflare Workers + D1 + R2.",
	"private": true,
	"dependencies": {
		"aws4fetch": "^1.0.20",
		"hono": "4.11.1",
		"zod": "3.25.67"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.14.6",
		"@types/node": "24.10.1",
		"typescript": "5.9.3",
		"vitest": "^4.1.4",
		"wrangler": "4.56.0"
	},
	"scripts": {
		"dev": "wrangler d1 migrations apply DB --local && wrangler dev",
		"deploy": "wrangler deploy",
		"predeploy": "wrangler d1 migrations apply DB --remote",
		"cf-typegen": "wrangler types",
		"test": "npm run test:run",
		"test:run": "vitest run --config tests/vitest.config.mts",
		"test:watch": "vitest --config tests/vitest.config.mts",
		"test:worker-check": "wrangler deploy --dry-run"
	}
}
