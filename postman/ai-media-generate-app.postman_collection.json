{
	"info": {
		"_postman_id": "8b88aa25-0c9a-4d5a-b4ce-1cf9c0ac6f9e",
		"name": "AI Media Generate App API",
		"description": "Postman collection for manual testing of the current Cloudflare Workers backend. Mobile routes that use development auth send `X-Dev-User-Id`; admin and internal routes currently do not enforce auth in code and are marked accordingly.",
