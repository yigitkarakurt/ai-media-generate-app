{
	"compatibility_date": "2025-10-08",
	"main": "src/index.ts",
	"name": "ai-media-generate-app",
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ai-video-app-db",
			"database_id": "fe26e0cf-a9a7-44e2-84f8-7d29b66c0a40",
			"migrations_dir": "migrations"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA_BUCKET",
			"bucket_name": "ai-media-assets"
		}
	],
	"vars": {
		"ENVIRONMENT": "development",
		"R2_BUCKET_NAME": "ai-media-assets"
	},
	"triggers": {
		"crons": ["*/2 * * * *"]
	}
	// Secrets (set via `wrangler secret put`):
	// - JWT_SECRET
	// - R2_ACCESS_KEY_ID
	// - R2_SECRET_ACCESS_KEY
	// - R2_ACCOUNT_ID
	// - ATLASCLOUD_API_KEY
	// - OPENROUTER_API_KEY
	// - REVENUECAT_WEBHOOK_SECRET
	// - ADMIN_API_KEY
	// - INTERNAL_API_KEY
	// Variables:
	// - ADMIN_PANEL_ORIGIN (e.g. https://ai-media-generate-admin.pages.dev)
}
